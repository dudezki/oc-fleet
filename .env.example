# Fleet RAG — Environment Variables
# Copy this file to .env and fill in all values before running deploy-proxmox.sh

# ── Anthropic (REQUIRED) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini (embeddings — REQUIRED) ──────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── OpenAI (embeddings — optional fallback) ──────────────────────────────────
# OPENAI_API_KEY=sk-proj-...

# ── Resend (email OTP) ───────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM="Callbox Fleet <noreply@yourdomain.com>"

# ── Supabase (optional — only if using cloud Supabase instead of local PG) ──
# SUPABASE_PROJECT_ID=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:fleetdev@127.0.0.1:5433/fleet_dev

# ── Local PostgreSQL (Docker — defaults work for local deploy) ───────────────
PG_USER=postgres
PG_PASSWORD=fleetdev
PG_DATABASE=fleet_dev
# DB_URL_LOCAL is auto-constructed from above (no need to set)

# ── Ollama (optional) ────────────────────────────────────────────────────────
# OLLAMA_API_KEY=

# ── Gateway Auth Tokens (REQUIRED — generate with: openssl rand -hex 32) ────
GATEWAY_TOKEN_RAG=
GATEWAY_TOKEN_SALES=
GATEWAY_TOKEN_SUPPORT=
GATEWAY_TOKEN_MANAGER=
GATEWAY_TOKEN_DEV=
GATEWAY_TOKEN_IT=

# ── Telegram Bot Tokens (REQUIRED) ───────────────────────────────────────────
BOT_TOKEN_SALES=
BOT_TOKEN_SUPPORT=
BOT_TOKEN_MANAGER=
BOT_TOKEN_DEV=
BOT_TOKEN_IT=

# ── Org UUID ─────────────────────────────────────────────────────────────────
ORG_ID=f86d92cb-db10-43ff-9ff2-d69c319d272d

# ── Google OAuth (for google-auth-proxy) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_VM_DOMAIN/google-auth/callback

# ── Dashboard path (if in a separate repo/dir) ───────────────────────────────
# DASHBOARD_DIR=/path/to/cbfleet-dashboard

# ── Additional Bot Tokens ────────────────────────────────────────────────────
BOT_TOKEN_HR=
BOT_TOKEN_FINANCE=

# ── Additional Gateway Tokens ────────────────────────────────────────────────
GATEWAY_TOKEN_HR=
GATEWAY_TOKEN_FINANCE=
